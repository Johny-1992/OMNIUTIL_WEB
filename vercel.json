{
  "version": 2,
  "builds": [
    { "src": "api/**/*.py", "use": "@vercel/python" },
    { "src": "package.json", "use": "@vercel/next" }
  ],
  "routes": [
    { "src": "/api/graft", "dest": "api/partner_engine.py" },
    { "src": "/api/claim", "dest": "api/claim.py" },
    { "src": "/api/exchange", "dest": "api/service_exchange.py" },
    { "src": "/partnership-request", "dest": "/partnership-request" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "env": {
    "ANNUAL_LIMIT": "1000000",
    "UTIL_PRICE_ANCHOR": "3650.96",
    "CONTRACT_BSC": "0xC8A3EA13b51C5e0a8e5c979d6A0b4BDa6bb1e76B",
    "OWNER_WALLET": "0x40BB46B9D10Dd121e7D2150EC3784782ae648090"
  }
}
